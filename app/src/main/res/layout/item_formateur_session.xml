<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="4dp"
    app:cardCornerRadius="8dp" app:cardElevation="2dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">
        <TextView android:id="@+id/tvSessionTitle" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="16sp" android:textStyle="bold" tools:text="Formation"/>
        <TextView android:id="@+id/tvSessionDate" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:textSize="14sp" tools:text="15/04/2026"/>
        <TextView android:id="@+id/tvSessionLocation" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:textSize="14sp" tools:text="Paris"/>
        <TextView android:id="@+id/tvNbInscrits" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:textSize="14sp" android:textStyle="italic" tools:text="5 inscrit(s)"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
